{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        {% if is_granted('ROLE_CONSUMER') %}
            <a href="{{ path('app_order_new') }}">Create new order</a>
        {% endif %}

        <table>
            <thead>
            <tr>
                <td>Id</td>
                <td>Package</td>
                <td>Consumer</td>
                <td>Created_at</td>
            </tr>
            </thead>
            {% for order in orders %}
                {% set  hasAccess = false %}
                {% if is_granted('ROLE_CONSUMER') and app.user.consumer == order.consumer %}
                    {% set hasAccess = true %}
                {% elseif is_granted('ROLE_BUSINESS') and app.user.business == order.package.business %}
                    {% set hasAccess = true %}
                {% elseif is_granted('ROLE_ADMIN') %}
                    {% set hasAcces = true %}
                {% endif %}
                <tr>
                    {% if hasAccess %}
                        <td><a href="{{ path('app_order_view',{
                                id : order.id,
                            }) }}"> {{ order.id }}</a></td>
                        <td>{{ order.package.name }}</td>
                        <td>{{ order.consumer.fullName }}</td>
                        <td>{{ order.created_at|date('d.m.y H:i') }}</td>
                    {% endif %}
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock %}
