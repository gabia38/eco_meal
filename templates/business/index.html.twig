{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <a href="{{ path ('app_business_new') }}"> Create new business</a>

        <table>
            <thead>
            <tr>
                <td>Id</td>
                <td>Name</td>
                <td>City</td>
                <td>Street</td>
                <td>House Number</td>
                <td>Phone Number</td>
                <td>Business Type</td>
            </tr>
            </thead>
            {% for business in businesses %}
                <tr>
                    <td><a href="{{ path ('app_business_view',{
                            id : business.id
                        }) }}"> {{ business.id }}</a></td>
                    <td>{{ business.name }}</td>
                    <td>{{ business.city }}</td>
                    <td>{{ business.street }}</td>
                    <td>{{ business.houseNumber }}</td>
                    <td>{{ business.phoneNumber }}</td>
                    <td>{{ business.houseNumber }}</td>
                    <td>{{ business.businessType.name }}</td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock %}
