{% extends 'base.html.twig' %}

{% block title %}Hello PackageController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <p>{{ package.id }}</p>
        <p>{{ package.name }}</p>
        <p>{{ package.description }}</p>
        <p>{{ package.price }}</p>
        <p>{{ package.business.name }}</p>
        <p>{{ package.photo }}</p>
        <p>{{ package.created_at|date('d.m.y H:i') }}</p>
        <p>{{ package.category.name }}</p>

        {% if is_granted('ROLE_CONSUMER') or is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_package') }}">back to all packages list</a>
        {% endif %}


        <a href="{{ path('app_package',{
            id : package.business.id
        }) }}">back to business packages list</a>

        {% if is_granted('ROLE_BUSINESS') %}
        <a href="{{ path('app_package_edit',{
            business_id : package.business.id,
            id : package.id
        }) }}">edit</a>

        <a href="{{ path('app_package_delete',{
            id : package.id
        }) }}">delete</a>
        {% endif %}
    </div>
{% endblock %}
