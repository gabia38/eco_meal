{% extends 'base.html.twig' %}

{% block title %}Hello ConsumerController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <a href="{{ path('app_consumer_new') }}">Create new consumer</a>

    <table>
        <thead>
        <tr>
            <td>Id</td>
            <td>First Name</td>
            <td>Last Name</td>
            <td>Phone</td>
        </tr>
        </thead>
        {% for consumer in consumers %}
            <tr>
                <td><a href="{{ path('app_consumer_view',{
                        id : consumer.id,
                    }) }}">{{ consumer.id }}</a></td>
                <td>{{ consumer.firstName }}</td>
                <td>{{ consumer.lastName }}</td>
                <td>{{ consumer.phoneNumber }}</td>
            </tr>
        {% endfor %}
    </table>
</div>
{% endblock %}
