<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}
        <style>
            body { background-color: lightgrey !important;}

            table {
                display: table;
                width: 60%;
                margin: 15px auto;
                border-collapse: collapse;
                background: white;
                border: 2px solid black;
            }
            th, td {
                padding: 12px 15px;
                text-align: center;
                border: 1px solid black;
            }

            table tbody tr:nth-child(odd),
            table tr:nth-child(odd) {
                background-color: whitesmoke;
            }

            table tbody tr:hover {
                background-color: powderblue;
            }

            .display-row {
                display: flex;
                flex-direction: column;
                justify-content: center;
                flex: 1 1 0;
                width: 0;
            }

            .password-requirements {
                list-style: none;
                padding: 0;
                margin: 8px 0 16px 0;
                display: none;
            }

            .password-requirements.is-visible {
                display: block;
            }

            .password-requirements li.invalid { color: #dc3545; }
            .password-requirements li.invalid::before { content: "✖  "; }
            .password-requirements li.valid { color: #28a745; }
            .password-requirements li.valid::before { content: "✔  "; }

            .filter-wrapper .package-filter-form {
                display: none;
            }

            .filter-wrapper.is-open .package-filter-form {
                display: flex;
            }
        </style>
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        <script>
            const passwordCriteria = {
                length: /.{8,}/,
                upper: /[A-Z]/,
                lower: /[a-z]/,
                number: /[0-9]/,
                special: /[!@#$%^&*(),.?":{}|<>]/
            };

            document.addEventListener('focusin', (event) => {
                if (event.target.matches('input[type="password"]')) {
                    const parent = event.target.closest('.password-group');
                    if (parent) {
                        const checklist = parent.querySelector('.password-requirements');
                        if (checklist) checklist.classList.add('is-visible');
                    }
                }
            });

            document.addEventListener('focusout', (event) => {
                if (event.target.matches('input[type="password"]')) {
                    const parent = event.target.closest('.password-group');
                    if (parent) {
                        const checklist = parent.querySelector('.password-requirements');
                        if (checklist) checklist.classList.remove('is-visible');
                    }
                }
            });

            document.addEventListener('input', (event) => {
                if (event.target.matches('input[type="password"]')) {
                    const parent = event.target.closest('.password-group');
                    if (!parent) return;

                    const checklist = parent.querySelector('.password-requirements');
                    if (!checklist) return;

                    const value = event.target.value;

                    Object.keys(passwordCriteria).forEach(key => {
                        const regex = passwordCriteria[key];
                        const element = checklist.querySelector(`[data-criterion="${key}"]`);

                        if (element) {
                            if (regex.test(value)) {
                                element.classList.remove('invalid');
                                element.classList.add('valid');
                            } else {
                                element.classList.remove('valid');
                                element.classList.add('invalid');
                            }
                        }
                    });
                }
            });

            document.addEventListener('click', (event) => {
                // Check if the user specifically clicked a filter toggle button
                if (event.target.matches('.filter-toggle-button')) {
                    const button = event.target;

                    // Find the closest parent wrapper container
                    const wrapper = button.closest('.filter-wrapper');
                    if (!wrapper) return;

                    // Toggle the visibility layout class
                    const isOpen = wrapper.classList.toggle('is-open');

                    // Dynamically rewrite the text label on the fly
                    if (isOpen) {
                        button.textContent = 'Hide';
                    } else {
                        button.textContent = 'Advanced Search';
                    }
                }
            });
        </script>
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
              integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    {% endif %}
</head>
<body>
{% block body %}{% endblock %}
</body>
</html>
